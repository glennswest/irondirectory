# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# ── Proxmox connection ──
proxmox_endpoint  = "https://pve.g8.lo:8006/"
proxmox_api_token = "user@realm!tokenid=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
node_name         = "pve"

# ── SSH key(s) injected into the fedora user ──
ci_ssh_public_keys = [
  "ssh-rsa AAAA... your-key-here",
]

# The etcd node map (dm1/dm2/dm3), image, and g8/MicroDNS defaults live in
# variables.tf. Override here only if needed, e.g.:
# etcd_version = "v3.6.12"
