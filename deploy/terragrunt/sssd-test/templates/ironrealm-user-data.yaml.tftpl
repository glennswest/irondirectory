#cloud-config
hostname: ${hostname}
fqdn: ${fqdn}
prefer_fqdn_over_hostname: true
manage_etc_hosts: true

users:
  - name: ${ci_user}
    groups: [wheel, adm, systemd-journal]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true
    ssh_authorized_keys:
%{ for key in ssh_keys ~}
      - ${key}
%{ endfor ~}

ssh_pwauth: false
disable_root: false

package_update: true
package_upgrade: false
packages:
  - qemu-guest-agent
  - git
  - gcc
  - gcc-c++
  - clang
  - openssl-devel
  - make
  - pkgconf-pkg-config
  - openldap-clients
  - protobuf-compiler

write_files:
  # Activates the OS-shipped, CMVP-validated fips.so provider (docs/FIPS.md)
  # -- iron-kdc refuses to start at all without FIPS active (unlike
  # iron-ldap, which fails closed on just the authenticated-bind path).
  - path: /root/fips.cnf
    permissions: "0644"
    content: |
      openssl_conf = openssl_init
      [openssl_init]
      providers = provider_sect
      [provider_sect]
      fips = fips_sect
      base = base_sect
      [base_sect]
      activate = 1
      [fips_sect]
      module = /usr/lib64/ossl-modules/fips.so
      activate = 1
      tls1-prf-ems-check = 1

  # Disposable "domain controller" for #7's SSSD e2e validation: builds
  # iron-kdcd/iron-ldapd FROM SOURCE (no released RPM covers the
  # SASL/GSSAPI work yet) and runs both directly rather than via RPM/
  # systemd -- this whole VM is meant to be destroyed once the
  # validation is done, so there's no packaging/upgrade concern to
  # design for.
  - path: /root/bootstrap.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euxo pipefail

      curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
      source "$HOME/.cargo/env"

      git clone --depth 1 --branch ${git_ref} https://github.com/glennswest/irondirectory.git /root/irondirectory
      cd /root/irondirectory

      export OPENSSL_CONF=/root/fips.cnf
      cargo build --release -p iron-kdc --bin iron-kdcd --bin iron-kdc-ctl
      cargo build --release -p iron-ldap --bin iron-ldapd

      export IRON_KDC_FASTETCD_ENDPOINT=${fastetcd_endpoint}
      export IRON_KDC_PARTITION_ID=${partition_id}
      export IRON_KDC_BASE_DN=${base_dn}
      export IRON_KDC_REALM=${krb5_realm}
      ./target/release/iron-kdc-ctl set-password krbtgt/${krb5_realm} "$(head -c32 /dev/urandom | base64)"
      ./target/release/iron-kdc-ctl set-password ${test_user} "${test_user_password}"
      ./target/release/iron-kdc-ctl set-password ldap/${fqdn} "$(head -c32 /dev/urandom | base64)"

      cat > /etc/systemd/system/iron-kdcd.service << EOF
      [Unit]
      Description=iron-kdcd (throwaway #7 test DC)
      After=network.target

      [Service]
      Environment=OPENSSL_CONF=/root/fips.cnf
      Environment=IRON_KDC_FASTETCD_ENDPOINT=${fastetcd_endpoint}
      Environment=IRON_KDC_PARTITION_ID=${partition_id}
      Environment=IRON_KDC_BASE_DN=${base_dn}
      Environment=IRON_KDC_REALM=${krb5_realm}
      Environment=IRON_KDC_LISTEN=0.0.0.0:88
      ExecStart=/root/irondirectory/target/release/iron-kdcd
      Restart=on-failure
      AmbientCapabilities=CAP_NET_BIND_SERVICE

      [Install]
      WantedBy=multi-user.target
      EOF

      cat > /etc/systemd/system/iron-ldapd.service << EOF
      [Unit]
      Description=iron-ldapd (throwaway #7 test DC)
      After=network.target

      [Service]
      Environment=OPENSSL_CONF=/root/fips.cnf
      Environment=IRON_LDAP_FASTETCD_ENDPOINT=${fastetcd_endpoint}
      Environment=IRON_LDAP_PARTITION_ID=${partition_id}
      Environment=IRON_LDAP_BASE_DN=${base_dn}
      Environment=IRON_LDAP_LISTEN=0.0.0.0:389
      Environment=IRON_LDAP_HEALTH_LISTEN=127.0.0.1:8080
      ExecStart=/root/irondirectory/target/release/iron-ldapd
      Restart=on-failure
      AmbientCapabilities=CAP_NET_BIND_SERVICE

      [Install]
      WantedBy=multi-user.target
      EOF

      systemctl daemon-reload
      systemctl enable --now iron-kdcd.service
      systemctl enable --now iron-ldapd.service

      # Give dave a posixAccount so SSSD's id_provider=ldap can resolve a
      # real uid/gid, and a matching posixGroup (RFC 2307).
      sleep 2
      cat > /root/dave-posix.ldif << 'EOF'
      dn: cn=${test_user},${base_dn}
      changetype: modify
      add: objectclass
      objectclass: posixAccount
      -
      add: uid
      uid: ${test_user}
      -
      add: uidNumber
      uidNumber: 10001
      -
      add: gidNumber
      gidNumber: 10001
      -
      add: homeDirectory
      homeDirectory: /home/${test_user}
      -
      add: loginShell
      loginShell: /bin/bash
      EOF
      ldapmodify -x -H ldap://127.0.0.1:389 -f /root/dave-posix.ldif

      cat > /root/dave-group.ldif << EOF
      dn: cn=${test_user}-group,${base_dn}
      objectclass: posixGroup
      cn: ${test_user}-group
      gidNumber: 10001
      memberUid: ${test_user}
      EOF
      ldapadd -x -H ldap://127.0.0.1:389 -f /root/dave-group.ldif

      touch /root/bootstrap-complete

runcmd:
  - [ systemctl, enable, --now, qemu-guest-agent ]
  - [ /root/bootstrap.sh ]

final_message: "${fqdn} throwaway iron-kdcd/iron-ldapd DC cloud-init complete in $UPTIME seconds"
