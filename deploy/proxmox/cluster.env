# irondirectory backing etcd cluster — Proxmox VM topology (D1: dedicated cluster).
#
# This is the single source of truth for the deploy tooling (ironetcd.sh).
# Edit here, never inline in the script.

# --- Proxmox host (runs `qm`) ---
PVE_HOST="root@pve.g8.lo"

# --- VM image (already staged on the PVE host) ---
IMAGE_PATH="/var/lib/vz/template/iso/Fedora-Cloud-Base-Generic-43-1.6.x86_64.qcow2"
CLOUD_USER="fedora"                # Fedora cloud image default login

# --- Storage / network ---
STORAGE="local-lvm"                # VM disks (lvmthin, ~962G free)
BRIDGE="vmbr0"                     # carries 192.168.8.0/24
NETMASK="24"
GATEWAY="192.168.8.1"
DNS_SERVER="192.168.8.252"         # g8.lo MicroDNS
SEARCH_DOMAIN="g8.lo"

# --- VM resources (minimal directory backend) ---
CORES="2"
MEMORY_MB="2048"
ROOT_DISK_GB="20"
DATA_DISK_GB="10"                  # dedicated disk mounted at /var/lib/etcd

# --- etcd (upstream now; fastetcd is a drop-in swap — same flags/env) ---
ETCD_FLAVOR="etcd"                 # etcd | fastetcd
ETCD_VERSION="v3.6.12"
ETCD_CLUSTER_TOKEN="irondir-etcd"
ETCD_DATA_DIR="/var/lib/etcd"

# --- SSH key injected via cloud-init (local path, .pub) ---
SSH_PUBKEY="${HOME}/.ssh/id_rsa.pub"

# --- Nodes: "name vmid ip" (one per line) ---
# Hostnames become <name>.<SEARCH_DOMAIN>; IPs are static, outside the
# DHCP pool (.100-.200).
NODES=(
  "dm1 131 192.168.8.41"
  "dm2 132 192.168.8.42"
  "dm3 133 192.168.8.43"
)

# --- g8.lo MicroDNS (for A/PTR records) ---
DNS_API="http://192.168.8.252:8080/api/v1"
DNS_ZONE_ID="9bed60c8-1664-4183-88f9-a1a21b927edc"          # g8.lo
DNS_PTR_ZONE_ID="c3d1c693-160c-483a-a53b-053775cceaaa"      # 8.168.192.in-addr.arpa
