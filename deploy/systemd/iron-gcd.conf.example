# Example /etc/iron-gcd/iron-gcd.conf for the iron-gcd.service unit.
# Loaded via systemd's EnvironmentFile=-, so a missing file is fine (the
# leading '-' makes it optional), but iron-gcd will refuse to start
# without these set somewhere -- unlike iron-ldapd/iron-kdcd's optional
# referral-topology config, iron-gcd's entire purpose is watching the
# forest topology, so it cannot run without it.

# Single-forest deployment (#12, this forest's own internal GC):
IRON_GC_CONFIG_FASTETCD_ENDPOINT=http://etcd.g8.lo:2379
IRON_GC_CONFIG_PARTITION_ID=g10-config
IRON_GC_CONFIG_BASE_DN=cn=configuration,dc=g10,dc=lo

# Federated GAL deployment (#13, D9): additional forests, `;`-separated,
# each `endpoint|partition-id|base-dn` (`|`, not `=`, since a DN is
# itself full of `=` signs). Combine with the single-forest trio above
# (or omit it and list every forest here) -- at least one forest must
# be configured one way or the other. A holdco-tier GAL deployment
# would typically pair this with a much stricter IRON_GC_ATTRIBUTES
# below than a single forest's own GC would use.
#IRON_GC_FORESTS=http://etcd.acme.lo:2379|acme-config|cn=configuration,dc=acme,dc=com;http://etcd.wontco.lo:2379|wontco-config|cn=configuration,dc=wontco,dc=com

#IRON_GC_LISTEN=0.0.0.0:3268
#IRON_GC_HEALTH_LISTEN=0.0.0.0:8080

# Optional implicit-TLS port (AD's GC convention: 3268 plaintext, 3269
# TLS). Both cert/key are required if IRON_GC_LDAPS_LISTEN is set.
#IRON_GC_LDAPS_LISTEN=0.0.0.0:3269
#IRON_GC_TLS_CERT=/etc/iron-gcd/tls.crt
#IRON_GC_TLS_KEY=/etc/iron-gcd/tls.key

# Optional comma-separated attribute whitelist -- the "partial" in
# partial replica. Unset uses iron_gc::aggregate::DEFAULT_ATTRIBUTES
# (objectclass, cn, uid, mail, displayname, sn, givenname, uidnumber,
# gidnumber), a conservative starting default for a single forest's own
# GC (#12). A federated GAL deployment (#13) crossing forest boundaries
# should set this to something stricter -- e.g. just the fields an
# address book actually needs:
#IRON_GC_ATTRIBUTES=objectclass,cn,mail,displayname
